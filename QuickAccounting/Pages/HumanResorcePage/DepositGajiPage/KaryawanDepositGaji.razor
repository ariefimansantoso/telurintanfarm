@page "/app/karyawandepositgaji"
@inject QuickAccounting.Repository.Interface.IDepositGajiService _depositService
@inject QuickAccounting.Repository.Interface.IEmployee _employee
@using QuickAccounting.Data.HrPayroll
@using System.Security.Claims
@inject IEmployee _employee
@inject IUser _userManage
@inject IPrivilege _privilege
@inject ISnackbar Snackbar
@inject NavigationManager navigation
@attribute [Authorize]

<PageTitle>Deposit Gaji</PageTitle>

<Loader IsLoading="isProcessing"></Loader>

<div class="content">
    <div class="page-header">
        <div class="page-title">
            <h4>Deposit Gaji</h4>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <div class="row mb-3">
                <div class="col-md-6">
                    <label>Karyawan</label>
                    <h5></h5>
                </div>

                <div class="col-md-6 text-right align-self-end">
                    
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-sm">
                    <thead>
                        <tr>                            
                            <th>Tanggal</th>
                            <th>Jumlah</th>
                            <th>Date Created</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (deposits != null && deposits.Count > 0)
                        {
                            foreach (var d in deposits)
                            {
                                <tr>
                                    <td>@d.DateCreated.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@d.DepositAmount.ToString("N2")</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center">Belum ada deposit.</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="2"><strong>Total Deposit</strong></td>
                            <td colspan="4"><strong>@totalPending.ToString("N2")</strong></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    [CascadingParameter] 
    public Task<AuthenticationState> AuthenticationState { get; set; }

    private bool isProcessing = false;
    private List<DepositGaji> deposits = new();
    private List<QuickAccounting.Data.HrPayroll.Employee> employees = new();
    private int selectedEmployeeId = 0;
    private decimal totalPending = 0;

    private bool CanDisburse => deposits != null && deposits.Any();
    private Dictionary<int, string> employeeNameCache = new();
    string strMenu = "Sales";
    UserMaster modelUser = new UserMaster();
    Employee modelEmployee = new Employee();
    string currentUserRole = "User";

    protected override async Task OnInitializedAsync()
    {
        isProcessing = true;
        var authstate = await AuthenticationState;
        var user = authstate.User;
        var userName = user.Identity.Name;
        currentUserRole = await _userManage.GetUserRole(userName);
        modelUser = await _userManage.UserProfile(userName);
        modelEmployee = await _employee.GetbyUserId(modelUser.UserId);
        var strShow = await _privilege.PriviliageCheck(strMenu, currentUserRole);
        if (strShow.ShowAction != true)
        {
            return;
        }

        await LoadDeposits();

        isProcessing = false;
        StateHasChanged();
    }

    private async Task LoadDeposits()
    {
        deposits.Clear();
        totalPending = 0;

        deposits = (await _depositService.GetActiveDepositByEmployeeIdAsync(modelEmployee.EmployeeId))?.ToList() ?? new List<DepositGaji>();

        totalPending = deposits.Sum(d => d.DepositAmount);
    }
}
