@page "/app/adminloanlist"
@using System.Security.Claims
@using System.Globalization
@using QuickAccounting.Data.HrPayroll
@inject QuickAccounting.Repository.Interface.ILoanService _loanService
@inject IEmployee _employee
@inject IPrivilege _privilege
@inject ISnackbar Snackbar
@inject NavigationManager navigation

<PageTitle>Daftar Pinjaman Karyawan</PageTitle>
<Loader IsLoading="isLoading"></Loader>

<div class="content">
    <div class="page-header">
        <div class="page-title">
            <h4>Daftar Pinjaman (Belum Lunas)</h4>
        </div>
        <div class="page-btn">
            @if (!showDetails && !isEditing)
            {
                <a class="btn btn-primary" href="/app/adminformloan">Tambah Pinjaman</a>
            }
            else
            {
                <button class="btn btn-secondary" @onclick="BackToList">Back</button>
            }
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            @if (!showDetails && !isEditing)
            {
                @if (pendingLoans != null && pendingLoans.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>No</th>
                                    <th>Karyawan</th>
                                    <th>Jumlah Pinjaman</th>
                                    <th>Jangka Waktu (bulan)</th>
                                    <th>Tanggal Dibuat</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    int no = 1;
                                }
                                @foreach (var loan in pendingLoans)
                                {
                                    <tr>
                                        <td>@no</td>
                                        <td>@(employeeNameCache.TryGetValue(loan.EmployeeID, out var ename) ? ename : "Unknown")</td>
                                        <td>@string.Format("{0:N2}", loan.LoanTotal)</td>
                                        <td>@loan.PaymentTermsInMonths</td>
                                        <td>@loan.CreatedDate.ToString("dd/MM/yyyy")</td>
                                        <td>
                                            <button class="btn btn-sm btn-primary me-1" @onclick="() => ShowDetailsAsync(loan.ID)">Details</button>
                                            <button class="btn btn-sm btn-warning" @onclick="() => StartEditAsync(loan.ID)">Edit</button>
                                        </td>
                                    </tr>
                                    no++;
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div style="text-align:center; padding:20px;">
                        <h5>Tidak ada pinjaman yang belum lunas.</h5>
                    </div>
                }
            }
            else if (isEditing)
            {
                <div>
                    <h5>Edit Pinjaman untuk: @(employeeNameCache.TryGetValue(editModel.EmployeeID, out var ename2) ? ename2 : "Unknown")</h5>

                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label>Jumlah Pinjaman</label>
                            <input type="number" step="0.01" class="form-control" value="@editModel.LoanTotal" @oninput="OnEditInputChanged" />
                        </div>
                        <div class="col-md-4">
                            <label>Jangka Waktu (bulan)</label>
                            <input type="number" class="form-control" value="@editModel.PaymentTermsInMonths" @oninput="OnEditPaymentChanged" />
                        </div>
                        <div class="col-md-4 align-self-end">
                            <button class="btn btn-success me-2" @onclick="UpdateLoanAsync">Update</button>
                            <button class="btn btn-secondary" @onclick="CancelEdit">Cancel</button>
                        </div>
                    </div>

                    <h6>Simulasi Angsuran</h6>
                    @if (simulatedDetails != null && simulatedDetails.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-bordered">
                                <thead>
                                    <tr>
                                        <th>No</th>
                                        <th>Bulan</th>
                                        <th>Tahun</th>
                                        <th>Jumlah</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        int i = 1;
                                    }
                                    @foreach (var s in simulatedDetails.OrderBy(x => x.Year).ThenBy(x => x.Month))
                                    {
                                        <tr>
                                            <td>@i</td>
                                            <td>@CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(s.Month)</td>
                                            <td>@s.Year</td>
                                            <td>@string.Format("{0:N2}", s.PaidAmount)</td>
                                        </tr>
                                        i++;
                                    }
                                </tbody>
                                <tfoot>
                                    <tr>
                                        <td colspan="3"><strong>Total</strong></td>
                                        <td><strong>@string.Format("{0:N2}", simulatedDetails.Sum(x => x.PaidAmount))</strong></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div>No simulation available.</div>
                    }
                </div>
            }
            else
            {
                <div>
                    <h5>Detail Angsuran untuk: @(employeeNameCache.TryGetValue(selectedLoan.EmployeeID, out var name) ? name : "Unknown")</h5>
                    <p>Jumlah Pinjaman: @string.Format("{0:N2}", selectedLoan.LoanTotal) &nbsp; | &nbsp; Jangka Waktu: @selectedLoan.PaymentTermsInMonths bulan</p>

                    @if (selectedLoanDetails != null && selectedLoanDetails.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-bordered">
                                <thead>
                                    <tr>
                                        <th>No</th>
                                        <th>Bulan</th>
                                        <th>Tahun</th>
                                        <th>Jumlah</th>
                                        <th>Status</th>
                                        <th>Tanggal Bayar</th>
                                        <th>Jumlah Bayar</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        int idx = 1;
                                    }
                                    @foreach (var d in selectedLoanDetails.OrderBy(x => x.Year).ThenBy(x => x.Month))
                                    {
                                        <tr>
                                            <td>@idx</td>
                                            <td>@CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(d.Month)</td>
                                            <td>@d.Year</td>
                                            <td>@string.Format("{0:N2}", d.PaidAmount)</td>
                                            <td>@(d.Paid ? "Paid" : "Pending")</td>
                                            <td>@(d.PaidDate == default ? "-" : d.PaidDate.ToString("dd/MM/yyyy"))</td>
                                            <td>@(d.Paid ? string.Format("{0:N2}", d.PaidAmount) : "-")</td>
                                        </tr>
                                        idx++;
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div style="text-align:center; padding:20px;">
                            <h6>Tidak ada detail angsuran untuk pinjaman ini.</h6>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

@code {
    [CascadingParameter] public Task<AuthenticationState> AuthenticationState { get; set; }

    private bool isLoading = true;
    private bool hasAccess = false;
    private bool showDetails = false;
    private bool isEditing = false;

    private List<LoanMaster> pendingLoans = new();
    private LoanMaster selectedLoan;
    private List<LoanDetails> selectedLoanDetails = new();

    // edit model & simulation
    private LoanMaster editModel = new();
    private List<LoanDetails> simulatedDetails = new();

    // cache employee names to avoid repeated DB calls
    private Dictionary<int, string> employeeNameCache = new();
    string strMenu = "Sales";

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        try
        {
            var authState = await AuthenticationState;
            var strRole = authState.User;
            string strName = strRole.FindFirst(ClaimTypes.Role).Value;
            var strShow = await _privilege.PriviliageCheck(strMenu, strName);
            if (strShow.ShowAction != true)
            {
                return;
            }

            await LoadLoansAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading loans: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadLoansAsync()
    {
        var all = await _loan_service_get_all_safe();
        pendingLoans = all.Where(l => !l.LoanCompleted).OrderByDescending(l => l.CreatedDate).ToList();

        // cache employee names
        var employeeIds = pendingLoans.Select(p => p.EmployeeID).Distinct();
        foreach (var eid in employeeIds)
        {            
            if (!employeeNameCache.ContainsKey(eid))
            {
                try
                {
                    var emp = await _employee.GetbyId(eid);
                    employeeNameCache[eid] = emp?.EmployeeName ?? "Unknown";
                }
                catch
                {
                    employeeNameCache[eid] = "Unknown";
                }
            }
        }        
    }

    private async Task<List<LoanMaster>> _loan_service_get_all_safe()
    {
        try
        {
            return await _loanService.GetAllAsync();            
        }
        catch (Exception ex)
        {
            Snackbar.Add($"LoanService.GetAllAsync error: {ex.Message}", Severity.Error);
            return new List<LoanMaster>();
        }
    }

    private async Task ShowDetailsAsync(int loanId)
    {
        isLoading = true;
        try
        {
            selectedLoan = pendingLoans.FirstOrDefault(l => l.ID == loanId);
            if (selectedLoan == null)
            {
                Snackbar.Add("Loan not found.", Severity.Warning);
                return;
            }

            selectedLoanDetails = await _loanService.GetLoanDetailsAsync(selectedLoan.ID);
            // ensure employee name cached
            if (!employeeNameCache.ContainsKey(selectedLoan.EmployeeID))
            {
                var emp = await _employee.GetbyId(selectedLoan.EmployeeID);
                employeeNameCache[selectedLoan.EmployeeID] = emp?.EmployeeName ?? "Unknown";
            }

            showDetails = true;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading loan details: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void BackToList()
    {
        showDetails = false;
        selectedLoan = null;
        selectedLoanDetails.Clear();
    }

    private async Task StartEditAsync(int loanId)
    {
        isLoading = true;
        try
        {
            var loan = await _loanService.GetByIdAsync(loanId);
            if (loan == null)
            {
                Snackbar.Add("Loan not found.", Severity.Warning);
                return;
            }

            editModel = new LoanMaster
            {
                ID = loan.ID,
                EmployeeID = loan.EmployeeID,
                LoanTotal = loan.LoanTotal,
                PaymentTermsInMonths = loan.PaymentTermsInMonths,
                CreatedDate = loan.CreatedDate,
                CreatedBy = loan.CreatedBy,
                LoanCompleted = loan.LoanCompleted
            };

            // initial simulation
            simulatedDetails = SimulateInstallments(editModel.LoanTotal, editModel.PaymentTermsInMonths);
            isEditing = true;
            showDetails = false;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error preparing edit: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void OnEditInputChanged(ChangeEventArgs e)
    {
        // 1. Manually update your model first
        if (decimal.TryParse(e.Value?.ToString(), out decimal newValue))
        {
            editModel.LoanTotal = newValue;
        }

        // Recompute simulation when inputs change
        simulatedDetails = SimulateInstallments(editModel.LoanTotal, editModel.PaymentTermsInMonths);
    }

    private void OnEditPaymentChanged(ChangeEventArgs e)
    {
        // 1. Manually update your model first
        if (int.TryParse(e.Value?.ToString(), out int newValue))
        {
            editModel.PaymentTermsInMonths = newValue;
        }

        // Recompute simulation when inputs change
        simulatedDetails = SimulateInstallments(editModel.LoanTotal, editModel.PaymentTermsInMonths);
    }

    private void CancelEdit()
    {
        isEditing = false;
        editModel = new LoanMaster();
        simulatedDetails.Clear();
    }

    private async Task UpdateLoanAsync()
    {
        if (editModel.PaymentTermsInMonths <= 0)
        {
            Snackbar.Add("Payment terms must be greater than zero.", Severity.Error);
            return;
        }
        if (editModel.LoanTotal <= 0)
        {
            Snackbar.Add("Loan total must be greater than zero.", Severity.Error);
            return;
        }

        isLoading = true;
        try
        {
            // Recreate details via service (service deletes old details and inserts new ones)
            var ok = await _loanService.RecreateLoanDetailsAsync(editModel.ID, editModel.LoanTotal, editModel.PaymentTermsInMonths);
            if (ok)
            {
                Snackbar.Add("Loan updated and schedule recreated.", Severity.Success);
                // reload list and return to list view
                await LoadLoansAsync();
                isEditing = false;
                showDetails = false;
                selectedLoan = null;
                selectedLoanDetails.Clear();
            }
            else
            {
                Snackbar.Add("Update failed.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error updating loan: {ex.Message} {ex.InnerException.Message} {ex.InnerException.StackTrace}", Severity.Error);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private List<LoanDetails> SimulateInstallments(decimal loanTotal, int terms)
    {
        var result = new List<LoanDetails>();
        if (terms <= 0 || loanTotal <= 0) return result;

        // base installment truncated to cents
        var baseInstallment = Math.Floor((loanTotal / terms) * 100) / 100m;
        decimal sumAssigned = 0m;
        for (int i = 0; i < terms; i++)
        {
            var due = DateTime.Now.AddMonths(i);
            int month = due.Month;
            int year = due.Year;
            decimal amount = baseInstallment;
            if (i == terms - 1)
            {
                amount = Math.Round(loanTotal - sumAssigned, 2);
            }
            sumAssigned += amount;
            result.Add(new LoanDetails
            {
                LoanMasterId = editModel?.ID ?? 0,
                Month = month,
                Year = year,
                Paid = false,
                PaidDate = default,
                PaidAmount = amount
            });
        }
        return result;
    }
}
