@page "/app/adminformloan"
@using System.Security.Claims
@using QuickAccounting.Data.HrPayroll
@inject QuickAccounting.Repository.Interface.ILoanService _loanService
@inject IEmployee _employee
@inject IUser _user
@inject IPrivilege _privilege
@inject ISnackbar Snackbar
@inject NavigationManager navigation

<PageTitle>Form Pinjaman Karyawan</PageTitle>
<Loader IsLoading="isLoading"></Loader>

<div class="content">
    <div class="page-header">
        <div class="page-title">
            <h4>Form Pinjaman Karyawan</h4>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <div class="row mb-3">
                <div class="col-lg-6">
                    <label>Karyawan</label>
                    <select class="form-control" @bind="SelectedEmployeeId">
                        <option value="0">-- Pilih Karyawan --</option>
                        @foreach (var e in EmployeeList)
                        {
                            <option value="@e.EmployeeId">@e.EmployeeName</option>
                        }
                    </select>
                </div>

                <div class="col-lg-3">
                    <label>Jumlah Pinjaman</label>
                    <input type="number" step="0.01" min="0" class="form-control" @bind="LoanTotal" />
                </div>

                <div class="col-lg-3">
                    <label>Jangka Waktu (bulan)</label>
                    <input type="number" min="1" class="form-control" @bind="PaymentTerms" />
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-lg-12">
                    <label>Preview Angsuran</label>
                    @if (Installments != null && Installments.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-striped">
                                <thead>
                                    <tr>
                                        <th>No</th>
                                        <th>Bulan</th>
                                        <th>Tahun</th>
                                        <th>Jumlah</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int i = 0; i < Installments.Count; i++)
                                    {
                                        <tr>
                                            <td>@(i + 1)</td>
                                            <td>@Installments[i].Month</td>
                                            <td>@Installments[i].Year</td>
                                            <td>@string.Format("{0:N2}", Installments[i].Amount)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-muted">Masukkan jumlah pinjaman dan jangka waktu untuk melihat preview angsuran.</div>
                    }
                </div>
            </div>

            <div class="row">
                <div class="col-lg-12" style="text-align:center;">
                    <button class="btn btn-submit me-2" @onclick="SaveLoanAsync" disabled="@IsSaving">Simpan Pinjaman</button>
                    <a class="btn btn-cancel" href="/app/kontraklist">Batal</a>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [CascadingParameter] public Task<AuthenticationState> AuthenticationState { get; set; }

    private List<Employee> EmployeeList = new();
    private int SelectedEmployeeId { get; set; } = 0;

    private decimal _loanTotal;
    private decimal LoanTotal
    {
        get => _loanTotal;
        set
        {
            if (_loanTotal != value)
            {
                _loanTotal = value;
                BuildInstallments();
            }
        }
    }

    private int _paymentTerms;
    private int PaymentTerms
    {
        get => _paymentTerms;
        set
        {
            if (_paymentTerms != value)
            {
                _paymentTerms = value;
                BuildInstallments();
            }
        }
    }

    private List<InstallmentView> Installments { get; set; } = new();
    private bool IsSaving { get; set; } = false;
    private UserMaster CurrentUser;
    private Employee CurrentEmployee;
    string strMenu = "Sales";
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        try
        {
            var authState = await AuthenticationState;
            var strRole = authState.User;
            string strName = strRole.FindFirst(ClaimTypes.Role).Value;
            var strShow = await _privilege.PriviliageCheck(strMenu, strName);
            if (strShow.ShowAction == true)
            {
                // load employees ordered by name asc
                EmployeeList = await _employee.GetAllEmployeeActive();

                var user = authState.User;
                var userName = user.FindFirst(ClaimTypes.Name)?.Value;
                if (!string.IsNullOrEmpty(userName))
                {
                    CurrentUser = await _user.UserProfile(userName);
                    CurrentEmployee = await _employee.GetbyUserId(CurrentUser.UserId);
                }
            }
            else
            {
                navigation.NavigateTo("/app/dashboard");
                Snackbar.Add("Anda tidak memiliki hak akses", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading employees: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void BuildInstallments()
    {
        Installments.Clear();

        if (LoanTotal <= 0 || PaymentTerms <= 0)
            return;

        // base installment truncated to 2 decimals so last installment absorbs remainder
        var baseInstallment = Math.Floor((LoanTotal / PaymentTerms) * 100) / 100m;
        decimal sumAssigned = 0m;

        var now = DateTime.Now;
        for (int i = 0; i < PaymentTerms; i++)
        {
            var dt = now.AddMonths(i);
            decimal amount = baseInstallment;

            if (i == PaymentTerms - 1)
            {
                amount = Math.Round(LoanTotal - sumAssigned, 2);
            }

            sumAssigned += amount;

            Installments.Add(new InstallmentView
            {
                Month = dt.Month,
                Year = dt.Year,
                Amount = amount
            });
        }

        StateHasChanged();
    }

    private async Task SaveLoanAsync()
    {
        if (SelectedEmployeeId == 0)
        {
            Snackbar.Add("Pilih karyawan terlebih dahulu.", Severity.Warning);
            return;
        }

        if (LoanTotal <= 0)
        {
            Snackbar.Add("Jumlah pinjaman harus lebih besar dari 0.", Severity.Warning);
            return;
        }

        if (PaymentTerms <= 0)
        {
            Snackbar.Add("Jangka waktu harus berupa angka bulan > 0.", Severity.Warning);
            return;
        }

        if (CurrentEmployee == null)
        {
            Snackbar.Add("Tidak dapat menentukan user saat ini.", Severity.Error);
            return;
        }

        IsSaving = true;

        try
        {
            var newId = await _loanService.CreateLoanAsync(SelectedEmployeeId, LoanTotal, PaymentTerms, CurrentEmployee.EmployeeId);
            if (newId > 0)
            {
                Snackbar.Add("Pinjaman berhasil dibuat.", Severity.Success);
                navigation.NavigateTo($"/app/adminloanlist");
            }
            else
            {
                Snackbar.Add("Gagal membuat pinjaman.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            IsSaving = false;
        }
    }

    private class InstallmentView
    {
        public int Month { get; set; }
        public int Year { get; set; }
        public decimal Amount { get; set; }
    }
}
