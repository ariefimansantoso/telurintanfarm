@page "/app/kontrak-detail/{kontrakId:int}"
@inject QuickAccounting.Repository.Interface.IKontrakKerjaService _kontrakService
@inject IEmployee _employee
@inject ISnackbar Snackbar
@inject IUser _user
@inject IPrivilege _privilege
@inject NavigationManager navigation
@inject IJSRuntime JSRuntime
@inject IAuditLogService _audit
@using System.Security.Claims
@attribute [Authorize]

<PageTitle>Detail Kontrak Kerja</PageTitle>

<div class="content">
    <div class="page-header">
        <div class="page-title">
            <h4>Detail Kontrak Kerja</h4>
        </div>        
    </div>

    <div class="card">
        <div class="card-body">
            @if (kontrak != null)
            {                
                <div class="mb-3">
                    <h5>Kontrak untuk: <strong>@employeeName</strong></h5>
                </div>

                <div class="card">
                    <div class="card-header">
                        <h6>Detail Kontrak</h6>
                        <small>
                            Tanggal Mulai: @kontrak.DateStart.ToString("dd/MM/yyyy")
                            &nbsp; | &nbsp;
                            Tanggal Berakhir: @(kontrak.IsPermanent ? "Permanen" : kontrak.DateEnd.ToString("dd/MM/yyyy"))
                        </small>
                    </div>
                    <div class="card-body">
                        <div>
                            @((MarkupString)kontrak.ContractDetails)
                        </div>

                        <div class="mt-3 d-flex align-items-center">
                            <div class="form-check me-3">
                                <input class="form-check-input" type="checkbox" id="isSignedCheckbox" @bind="kontrak.IsSigned" />
                                <label class="form-check-label" for="isSignedCheckbox">
                                    Tanda tangan/Setujui kontrak secara elektronik/online
                                </label>
                            </div>                           
                        </div>

                        <div>
                            <br /><br />
                            <button class="btn btn-sm btn-primary me-2" @onclick="SaveSignatureAsync">
                                Simpan Tanda Tangan
                            </button>

                            <a class="btn btn-sm btn-secondary" href="/app/dashboard">Kembali</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter]
    public int kontrakId { get; set; }

    [CascadingParameter]
    public Task<AuthenticationState> AuthenticationState { get; set; }

    private QuickAccounting.Data.HrPayroll.KontrakKerja kontrak;
    private string employeeName = "Unknown";
    private bool isLoading = true;
    private bool hasAccess = true;
    private UserMaster currentUser;
    private Employee currentEmployee;
    private Dictionary<int, string> userNameCache = new();

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        try
        {
            var authState = await AuthenticationState;
            var user = authState.User;
            var roleName = user.FindFirst(ClaimTypes.Role)?.Value;
            // var privilege = await _privilege.PriviliageCheck("Form Kontrak Kerja", roleName);
            // hasAccess = privilege.ShowAction;

            // if (!hasAccess)
            // {
            //     return;
            // }

            var userName = user.FindFirst(ClaimTypes.Name)?.Value;
            currentUser = await _user.UserProfile(userName);

            kontrak = await _kontrakService.GetByIdAsync(kontrakId);
            if (kontrak != null)
            {
                var emp = await _employee.GetbyId(kontrak.EmployeeID);
                employeeName = emp?.EmployeeName ?? "Unknown";
            }

            // load current employee (for audit fields)
            if (currentUser != null)
            {
                currentEmployee = await _employee.GetbyUserId(currentUser.UserId);
            }

            string auditMessage = "User dengan nama " + currentEmployee.EmployeeName + " mengunjungi Form Tanda Tangan Kontrak Kerja.";
            await _audit.LogAsync(LogTypes.LogInfo, "Form Tanda Tangan Kontrak", auditMessage, currentEmployee.EmployeeId, currentEmployee.EmployeeName);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading kontrak: {ex.Message}", Severity.Error);
        }
        
        isLoading = false;
        StateHasChanged();
    }

    private async Task SaveSignatureAsync()
    {
        if (kontrak == null) return;

        try
        {
            // ensure signed flag and audit fields are set
            kontrak.IsSigned = true;
            kontrak.DateModified = DateTime.Now;
            kontrak.ModifiedBy = currentEmployee?.EmployeeId;

            var updated = await _kontrakService.UpdateAsync(kontrak);
            if (updated)
            {
                string auditMessage = "User dengan nama " + currentEmployee.EmployeeName + " menandatangani Kontrak Kerja ID: " + kontrakId;
                await _audit.LogAsync(LogTypes.LogInfo, "Form Tanda Tangan Kontrak", auditMessage, currentEmployee.EmployeeId, currentEmployee.EmployeeName);

                Snackbar.Add("Tanda tangan berhasil disimpan.", Severity.Success);
                StateHasChanged();
            }
            else
            {
                Snackbar.Add("Gagal menyimpan tanda tangan.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving signature: {ex.Message}", Severity.Error);
        }
    }

    private string GetUserName(int userId)
    {
        if (userNameCache.ContainsKey(userId)) return userNameCache[userId];

        var user = _user.UserProfile(userId.ToString()).Result;
        var name = user?.UserName ?? "Tidak ada nama";
        userNameCache[userId] = name;
        return name;
    }

    // small workaround to satisfy analyzer while editing - removed at runtime.
    private Task<QuickAccounting.Data.HrPayroll.KontrakKerja> _kontrak_service_or_get()
        => Task.FromResult<QuickAccounting.Data.HrPayroll.KontrakKerja>(null);
}