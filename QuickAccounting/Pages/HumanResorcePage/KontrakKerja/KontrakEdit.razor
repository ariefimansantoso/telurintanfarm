@page "/app/kontrak-edit/{Id}"
@inject QuickAccounting.Repository.Interface.IKontrakKerjaService _kontrakService
@inject IEmployee _employee
@inject ISnackbar Snackbar
@inject IUser _user
@inject IPrivilege _privilege
@inject NavigationManager navigation
@inject IJSRuntime JSRuntime
@using System.Security.Claims
@attribute [Authorize]

<PageTitle>Edit Kontrak Kerja Karyawan</PageTitle>
<div class="content">
    <div class="page-header">
        <div class="page-title">
            <h4>Edit Kontrak Kerja Karyawan</h4>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            @if (Model != null && !FormSubmitted)
            {
                <div class="row">
                    <div class="col-lg-4 col-sm-6 col-12">
                        <div class="form-group">
                            <label>Ditujukan Kepada</label>
                            <div class="row">
                                <div class="col-lg-12 col-sm-12 col-12">
                                    <select class="form-control" @onchange="OnEmployeeChanged" disabled>
                                        @foreach (var employee in EmployeeList)
                                        {
                                            <option value="@employee.EmployeeId" selected="@(employee.EmployeeId == Model.EmployeeID)">@employee.EmployeeName</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-lg-4 col-sm-6 col-12">
                        <div class="form-group">
                            <label>Tanggal Mulai</label>
                            <div class="row">
                                <div class="col-lg-12 col-sm-12 col-12">
                                    <RadzenDatePicker @bind-Value="Model.DateStart" DateFormat="d" Class="w-100" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-4 col-sm-6 col-12">
                        <div class="form-group">
                            <label>Tanggal Berakhir</label>
                            <div class="row">
                                <div class="col-lg-12 col-sm-12 col-12">
                                    <RadzenDatePicker @bind-Value="Model.DateEnd" DateFormat="d" Class="w-100" />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-lg-8 col-sm-12 col-12">
                        <div class="form-group">
                            <label>Detail Kontrak</label>
                            <div class="row">
                                <div class="col-lg-12 col-sm-12 col-12">
                                    <div id="quill-editor-kontrak-edit" style="height: 400px; width: 100%;"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-lg-4 col-sm-6 col-12">
                        <div class="form-group">
                            <label>Kontrak Permanen</label>
                            <div class="row">
                                <div class="col-lg-12 col-sm-12 col-12">
                                    <input type="checkbox" @bind="Model.IsPermanent" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-4 col-sm-6 col-12">
                        <div class="form-group">
                            <label>Expired</label>
                            <div class="row">
                                <div class="col-lg-12 col-sm-12 col-12">
                                    <input type="checkbox" @bind="Model.IsExpired" />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <br />
                <div class="row">
                    <div class="col-lg-12" style="text-align: center !important;">
                        <input type="button" @onclick="@UpdateKontrakKerja" class="btn btn-submit me-2" value="Perbarui" />
                        <a href="/app/kontraklist" class="btn btn-cancel">Kembali</a>
                    </div>
                </div>
            }
            else if (FormSubmitted)
            {
                <div class="row">
                    <div class="col-lg-4 col-sm-6 col-12">
                        <div class="form-group" style="text-align: center !important;">
                            <label style="font-size:24px; font-weight:bold;">Kontrak Kerja berhasil diperbarui.</label>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-lg-12" style="text-align: center !important;">
                        <a href="/app/kontraklist" class="btn btn-submit me-2">Kembali ke Daftar</a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string Id { get; set; }

    [CascadingParameter]
    public Task<AuthenticationState> AuthenticationState { get; set; }

    private QuickAccounting.Data.HrPayroll.KontrakKerja Model = new QuickAccounting.Data.HrPayroll.KontrakKerja();
    private List<Employee> EmployeeList = new List<Employee>();
    private UserMaster ModelUser = new UserMaster();
    private Employee modelEmployee;
    private bool FormSubmitted = false;
    private string MenuName = "Form Kontrak Kerja";
    bool hasRendered = false;
    private DotNetObjectReference<KontrakEdit> _objRef;
    protected override async Task OnInitializedAsync()
    {
        var authorized = await CheckPermission();
        if (!authorized)
        {
            navigation.NavigateTo("/app/dashboard");
            Snackbar.Add("Anda tidak memiliki hak akses.", Severity.Error);
            return;
        }

        var authState = await AuthenticationState;
        var currentUser = authState.User;
        string userName = currentUser.FindFirst(ClaimTypes.Name).Value;
        ModelUser = await _user.UserProfile(userName);
        modelEmployee = await _employee.GetbyUserId(ModelUser.UserId);

        await LoadEmployeeList();        

        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {                   
            await LoadKontrakKerja();
            _objRef = DotNetObjectReference.Create(this);
            await JSRuntime.InvokeVoidAsync("quillInterop.initializeQuill", "quill-editor-kontrak-edit", Model.ContractDetails, _objRef, "EditKontrakContent");            
        }
    }

    private async Task<bool> CheckPermission()
    {
        try
        {
            var authState = await AuthenticationState;
            var userRole = authState.User;
            string roleName = userRole.FindFirst(ClaimTypes.Role).Value;
            var privilege = await _privilege.PriviliageCheck(MenuName, roleName);
            return privilege.ShowAction;
        }
        catch
        {
            return false;
        }
    }

    private async Task LoadEmployeeList()
    {
        try
        {
            EmployeeList = await _employee.GetAllEmployeeActive();
            EmployeeList = EmployeeList.OrderBy(x => x.EmployeeName).ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading employees: {ex.Message}", Severity.Error);
        }
    }

    private async Task LoadKontrakKerja()
    {
        try
        {
            int recordId = Convert.ToInt32(Id);
            var kontrak = await _kontrakService.GetByIdAsync(recordId);
            if (kontrak == null)
            {
                Snackbar.Add("Kontrak kerja tidak ditemukan.", Severity.Error);
                navigation.NavigateTo("/app/kontraklist");
                return;
            }

            Model = kontrak;
            // Ensure non-null contract details for editor
            //Model.ContractDetails ??= string.Empty;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading data: {ex.Message}", Severity.Error);
        }
    }

    private async Task OnEmployeeChanged(ChangeEventArgs e)
    {
        try
        {
            int employeeId = Convert.ToInt32(e.Value.ToString());
            if (employeeId > 0)
            {
                Model.EmployeeID = employeeId;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private async Task UpdateKontrakKerja()
    {
        try
        {
            // Get content from Quill editor
            Model.ContractDetails = await JSRuntime.InvokeAsync<string>("quillInterop.getQuillContent", "quill-editor-kontrak-edit");

            if (Model.EmployeeID == 0)
            {
                Snackbar.Add("Mohon pilih karyawan terlebih dahulu.", Severity.Warning);
                return;
            }

            if (Model.DateStart == DateTime.MinValue || (Model.DateEnd == DateTime.MinValue && !Model.IsPermanent))
            {
                Snackbar.Add("Tanggal mulai dan (jika bukan permanen) tanggal berakhir harus diisi.", Severity.Warning);
                return;
            }

            if (Model.DateEnd < Model.DateStart && !Model.IsPermanent)
            {
                Snackbar.Add("Tanggal berakhir harus lebih besar atau sama dengan tanggal mulai, kecuali untuk kontrak permanen.", Severity.Warning);
                return;
            }

            Model.ModifiedBy = modelEmployee.EmployeeId;
            Model.DateModified = DateTime.Now;

            var result = await _kontrakService.UpdateAsync(Model);

            if (result)
            {
                Snackbar.Add("Kontrak kerja berhasil diperbarui.", Severity.Success);
                FormSubmitted = true;
                StateHasChanged();
            }
            else
            {
                Snackbar.Add("Gagal memperbarui kontrak kerja. Silakan coba lagi.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    [JSInvokable]
    public void EditKontrakContent(string content) => Model.ContractDetails = content;

    public void Dispose() => _objRef?.Dispose();
}