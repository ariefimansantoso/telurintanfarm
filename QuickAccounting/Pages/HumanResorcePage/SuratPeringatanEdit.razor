@page "/app/suratperingatan-edit/{Id}"
@inject ISuratPeringatan _suratPeringatan
@inject IEmployee _employee
@inject ISnackbar Snackbar
@inject IUser _user
@inject IPrivilege _privilege
@inject NavigationManager navigation
@inject IJSRuntime JSRuntime
@using System.Security.Claims
@attribute [Authorize]

<PageTitle>Edit Surat Peringatan Karyawan</PageTitle>
<div class="content">
    <div class="page-header">
        <div class="page-title">
            <h4>Edit Surat Peringatan Karyawan</h4>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            @if (Model != null && !FormSubmitted)
            {
                <div class="row">
                    <div class="col-lg-4 col-sm-6 col-12">
                        <div class="form-group">
                            <label>Ditujukan Kepada</label>
                            <div class="row">
                                <div class="col-lg-12 col-sm-12 col-12">
                                    <select class="form-control" @onchange="OnEmployeeChanged" disabled>
                                        @foreach (var employee in EmployeeList)
                                        {
                                            <option value="@employee.EmployeeId" selected="@(employee.EmployeeId == Model.EmployeeId)">@employee.EmployeeName</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-lg-4 col-sm-6 col-12">
                        <div class="form-group">
                            <label>Nomor Surat</label>
                            <div class="row">
                                <div class="col-lg-12 col-sm-12 col-12">
                                    <input type="text" class="form-control" @bind="Model.SPOfficialNumber" placeholder="Nomor Surat" />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-lg-4 col-sm-6 col-12">
                        <div class="form-group">
                            <label>Tanggal Surat Peringatan</label>
                            <div class="row">
                                <div class="col-lg-12 col-sm-12 col-12">
                                    <RadzenDatePicker @bind-Value="@Model.DateCreated" DateFormat="d" Class="w-100" />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-lg-8 col-sm-12 col-12">
                        <div class="form-group">
                            <label>Isi Surat Peringatan</label>
                            <div class="row">
                                <div class="col-lg-12 col-sm-12 col-12">
                                    <div id="quill-editor-surat-peringatan-edit" style="height: 400px; width: 100%;"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <br />
                <div class="row">
                    <div class="col-lg-12" style="text-align: center !important;">
                        <input type="button" @onclick="@UpdateSuratPeringatan" class="btn btn-submit me-2" value="Perbarui" />
                        <a href="/app/suratperingatanbyemployee" class="btn btn-cancel">Kembali</a>
                    </div>
                </div>
            }
            else if (FormSubmitted)
            {
                <div class="row">
                    <div class="col-lg-4 col-sm-6 col-12">
                        <div class="form-group" style="text-align: center !important;">
                            <label style="font-size:24px; font-weight:bold;">Surat Peringatan berhasil diperbarui.</label>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-lg-12" style="text-align: center !important;">
                        <a href="/app/suratperingatanbyemployee" class="btn btn-submit me-2">Kembali ke Daftar</a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string Id { get; set; }

    [CascadingParameter]
    public Task<AuthenticationState> AuthenticationState { get; set; }

    private static SuratPeringatan Model = new SuratPeringatan();
    private List<Employee> EmployeeList = new List<Employee>();
    private UserMaster ModelUser = new UserMaster();
    private Employee modelEmployee;
    private bool FormSubmitted = false;
    private string MenuName = "Form Surat Peringatan";

    private DotNetObjectReference<SuratPeringatanEdit> _objRef;
    protected override async Task OnInitializedAsync()
    {
        var authorized = await CheckPermission();
        if (!authorized)
        {
            navigation.NavigateTo("/app/dashboard");
            Snackbar.Add("Anda tidak memiliki hak akses.", Severity.Error);
            return;
        }

        var authState = await AuthenticationState;
        var currentUser = authState.User;
        string userName = currentUser.FindFirst(ClaimTypes.Name).Value;
        ModelUser = await _user.UserProfile(userName);
        modelEmployee = await _employee.GetbyUserId(ModelUser.UserId);

        await LoadEmployeeList();
        await LoadSuratPeringatan();

        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && Model != null)
        {
            // Initialize Quill editor with existing content
            //await JSRuntime.InvokeVoidAsync("quillInterop.initializeQuill", "quill-editor-surat-peringatan-edit", Model.SpDescription ?? "");
            _objRef = DotNetObjectReference.Create(this);

            // Pass the reference into your JS initialization
            await JSRuntime.InvokeVoidAsync("quillInterop.initializeQuill", "quill-editor-surat-peringatan-edit", Model.SpDescription, _objRef, "EditSuratPeringatan");
        }
    }

    private async Task<bool> CheckPermission()
    {
        try
        {
            var authState = await AuthenticationState;
            var userRole = authState.User;
            string roleName = userRole.FindFirst(ClaimTypes.Role).Value;
            var privilege = await _privilege.PriviliageCheck(MenuName, roleName);
            return privilege.ShowAction;
        }
        catch
        {
            return false;
        }
    }

    private async Task LoadEmployeeList()
    {
        try
        {
            EmployeeList = await _employee.GetAllEmployeeActive();
            EmployeeList = EmployeeList.OrderBy(x => x.EmployeeName).ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading employees: {ex.Message}", Severity.Error);
        }
    }

    private async Task LoadSuratPeringatan()
    {
        try
        {
            int recordId = Convert.ToInt32(Id);
            Model = await _suratPeringatan.GetByID(recordId);
            if (Model == null)
            {
                Snackbar.Add("Surat peringatan tidak ditemukan.", Severity.Error);
                navigation.NavigateTo("/app/suratperingatanbyemployee");
            }
            //await JSRuntime.InvokeVoidAsync("quillInterop.initializeQuill", "quill-editor-surat-peringatan-edit", Model.SpDescription ?? "");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading data: {ex.Message}", Severity.Error);
        }
    }

    private async Task OnEmployeeChanged(ChangeEventArgs e)
    {
        try
        {
            int employeeId = Convert.ToInt32(e.Value.ToString());
            if (employeeId > 0)
            {
                Model.EmployeeId = employeeId;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private async Task UpdateSuratPeringatan()
    {
        try
        {
            // Get content from Quill editor
            Model.SpDescription = await JSRuntime.InvokeAsync<string>("quillInterop.getQuillContent", "quill-editor-surat-peringatan-edit");

            if (Model.SPOfficialNumber == "")
            {
                Snackbar.Add("Nomor surat tidak boleh kosong.", Severity.Warning);
                return;
            }

            if (string.IsNullOrWhiteSpace(Model.SpDescription) || Model.SpDescription == "<p><br></p>")
            {
                Snackbar.Add("Isi surat peringatan tidak boleh kosong.", Severity.Warning);
                return;
            }

            Model.ModifiedBy = modelEmployee.EmployeeId;
            Model.DateModified = DateTime.Now;

            var result = await _suratPeringatan.Update(Model);

            if (result)
            {
                Snackbar.Add("Surat peringatan berhasil diperbarui.", Severity.Success);
                FormSubmitted = true;
                StateHasChanged();
            }
            else
            {
                Snackbar.Add("Gagal memperbarui surat peringatan. Silakan coba lagi.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    [JSInvokable]
    public void EditSuratPeringatan(string content) => Model.SpDescription = content;

    public void Dispose() => _objRef?.Dispose();
}