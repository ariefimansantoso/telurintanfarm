    private void PrepareData()
    {
        AllKandang = new List<ReportAllKandang>();
        var grouped = DailyRecordings.GroupBy(x => x.CageNumber).ToList();

        foreach (var itemGroup in grouped)
        {
            var group = itemGroup.OrderByDescending(x => x.RecordDate).ToList();
            var reportKandangItem = new ReportAllKandang();

            // ... (Paste all your existing LINQ queries here, like populationStart, etc.) ...
            var populationStart = group.Select(x => x.PopulationStart).FirstOrDefault();
            var foodNeededTodayKg = group.Select(x => x.FoodNeededTodayKg).FirstOrDefault();
            var foodIntakePerHen = group.Select(x => x.FoodIntakePerHen).FirstOrDefault();
            var totalEggCount = group.Select(x => x.TotalEggCount).FirstOrDefault();
            var totalEggKg = group.Select(x => x.TotalEggKg).FirstOrDefault();
            var actualHenDay = group.Select(x => x.ActualHenDay).FirstOrDefault();
            var feedConversionRatio = group.Select(x => x.FeedConversionRatio).FirstOrDefault();

            // 1. Calculate the values
            decimal hd = 0;
            try { hd = ((decimal)totalEggCount / (decimal)populationStart) * 100M; }
            catch { hd = ((decimal)actualHenDay / (decimal)group.Count()); }

            decimal fcr = 0;
            try { fcr = foodNeededTodayKg / totalEggKg; }
            catch { fcr = (feedConversionRatio / (decimal)group.Count()); }

            // 2. Assign to your object
            reportKandangItem.Kandang = Convert.ToInt32(itemGroup.Key);
            reportKandangItem.FI = foodIntakePerHen.ToString("N2");
            reportKandangItem.PersenHD = hd.ToString("N2");
            reportKandangItem.FCR = fcr.ToString("N2");

            // Assign your other properties...

            AllKandang.Add(reportKandangItem);
        }

        // Apply default sort when data loads
        Sort("KDG");
    }

    // The Sorting Logic
    private void Sort(string column)
    {
        // Toggle sort direction if clicking the same column
        if (currentSortColumn == column)
        {
            isAscending = !isAscending;
        }
        else
        {
            currentSortColumn = column;
            isAscending = true;
        }

        switch (column)
        {
            case "KDG":
                AllKandang = isAscending
                    ? AllKandang.OrderBy(x => x.Kandang).ToList()
                    : AllKandang.OrderByDescending(x => x.Kandang).ToList();
                break;
            case "FI":
                AllKandang = isAscending
                    ? AllKandang.OrderBy(x => decimal.Parse(x.FI)).ToList()
                    : AllKandang.OrderByDescending(x => decimal.Parse(x.FI)).ToList();
                break;
            case "%HD":
                AllKandang = isAscending
                    ? AllKandang.OrderBy(x => decimal.Parse(x.PersenHD)).ToList()
                    : AllKandang.OrderByDescending(x => decimal.Parse(x.PersenHD)).ToList();
                break;
            case "FCR":
                AllKandang = isAscending
                    ? AllKandang.OrderBy(x => decimal.Parse(x.FCR)).ToList()
                    : AllKandang.OrderByDescending(x => decimal.Parse(x.FCR)).ToList();
                break;
        }
    }

    private async Task LoadRecording()
    {
        isProcessing = true;
        StateHasChanged();                

        DailyRecordings = await _recording.GetRecordingsByKandang("ALL"); //, dtFromDate, dtToDate);
        DailyRecordings = DailyRecordings.Where(x => x.RecordDate <= ReportDate.Date).ToList();
        DailyRecordings = DailyRecordings.OrderBy(x => Convert.ToInt32(x.CageNumber)).ToList();

        PrepareData();

        isProcessing = false;
        StateHasChanged();
    }

    protected override async Task OnInitializedAsync()
    {
