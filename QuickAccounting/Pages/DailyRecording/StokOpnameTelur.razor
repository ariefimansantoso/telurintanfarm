            var dateNow = DateTime.Now;

            int productIdBentes = 16;
            int productIdPutih = 7;
            int productIdParah = 17;
            int productIdPS = 19;
            int productIdRusak = 106;

            await LoadDataStock();

            // telur utuh
            var stock = new StockOpnam
            {
                ProductID = -99,
                GroupId = 6,
                StockAkhir = Kilogram,
                StockDate = dateNow,
                CreatedDate = DateTime.Now,
