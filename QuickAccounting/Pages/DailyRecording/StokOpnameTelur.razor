    private async Task OnKilogramChanged(ChangeEventArgs e)
    {
        if (e.Value.ToString().Contains(","))
        {
            Snackbar.Add("Input Telur Utuh tidak benar. Mohon pakai TITIK.", Severity.Warning);
            IsValid = false;
            return;
        }

        decimal v;
        if (decimal.TryParse(e.Value.ToString(), NumberStyles.Any, CultureInfo.InvariantCulture, out v))
        {
            IsValid = true;
            Kilogram = v;            
        }
        else
        {
            IsValid = false;
            Snackbar.Add("Input Telur Utuh tidak benar.", Severity.Warning);
        }
    }

