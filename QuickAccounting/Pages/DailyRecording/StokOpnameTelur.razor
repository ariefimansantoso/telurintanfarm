                GroupId = 6,
                StockAkhir = StockTelurPutihCapture,
                StockDate = dateNow,
                CreatedDate = DateTime.Now,
                CreatedBy = modelEmployee.EmployeeId,
                 Capture = true
            };

            var stockBentesCapture = new StockOpnam
            {
                ProductID = productIdBentes,
                GroupId = 6,
                StockAkhir = StockTelurBentesCapture,
                StockDate = dateNow,
                CreatedDate = DateTime.Now,
                CreatedBy = modelEmployee.EmployeeId,
