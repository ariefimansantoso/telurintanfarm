    private async Task Save()   
    {
        try
        {
            string auditMessage = "";
            var dateNow = DateTime.Now;

            int productIdBentes = 16;
            int productIdPutih = 7;
            int productIdParah = 17;
            int productIdPS = 19;
            int productIdRusak = 106;

            // telur utuh
            var stock = new StockOpnam
            {
                ProductID = -99,
                GroupId = 6,
                StockAkhir = Kilogram,
                StockDate = dateNow,
                CreatedDate = DateTime.Now,
                CreatedBy = modelEmployee.EmployeeId
            };

            var stockPutih = new StockOpnam
            {
                ProductID = productIdPutih,
                GroupId = 6,
                StockAkhir = KilogramPutih,
                StockDate = dateNow,
                CreatedDate = DateTime.Now,
                CreatedBy = modelEmployee.EmployeeId
            };

            var stockBentes = new StockOpnam
            {
                ProductID = productIdBentes,
                GroupId = 6,
                StockAkhir = KilogramBentes,
                StockDate = dateNow,
                CreatedDate = DateTime.Now,
                CreatedBy = modelEmployee.EmployeeId
            };

            var stockParah = new StockOpnam
            {
                ProductID = productIdParah,
                GroupId = 6,
                StockAkhir = KilogramParah,
                StockDate = dateNow,
                CreatedDate = DateTime.Now,
                CreatedBy = modelEmployee.EmployeeId
            };

            var stockPS = new StockOpnam
            {
                ProductID = productIdPS,
                GroupId = 6,
                StockAkhir = KilogramPS,
                StockDate = dateNow,
                CreatedDate = DateTime.Now,
                CreatedBy = modelEmployee.EmployeeId
            };

            var stockRusak = new StockOpnam
            {
                ProductID = productIdRusak,
                GroupId = 6,
                StockAkhir = KilogramRusak,
                StockDate = dateNow,
                CreatedDate = DateTime.Now,
                CreatedBy = modelEmployee.EmployeeId
            };
            
            List<StockOpnam> StockAkhirs = new List<StockOpnam>();
            StockAkhirs.Add(stock);
            StockAkhirs.Add(stockPutih);
            StockAkhirs.Add(stockBentes);
            StockAkhirs.Add(stockParah);
            StockAkhirs.Add(stockPS);
            StockAkhirs.Add(stockRusak);

            try
            {
                await _stockAkhirService.CreateAllAsync(StockAkhirs);
                await _db.SaveChangesAsync();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error saving data: {ex.InnerException.Message}", Severity.Error);
                return;
            }

            Snackbar.Add("Stok Opnam Telur berhasil.", Severity.Success);
            navigation.NavigateTo("/app/resetsalesstock", true);
        }
        catch (DbUpdateException dex)
        {
            Snackbar.Add("Error: " + dex.Message + Environment.NewLine + dex.InnerException?.Message, Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add("Error e: " + ex.Message + Environment.NewLine + ex.StackTrace, Severity.Error);
        }
    }    
    
    protected override async Task OnInitializedAsync()
    {
        var authstate = await authStateProvider.GetAuthenticationStateAsync();
        var user = authstate.User;
        var userName = user.Identity.Name;
        currentUserRole = await _user.GetUserRole(userName);
        modelUser = await _user.UserProfile(userName);
        modelEmployee = await _employee.GetbyUserId(modelUser.UserId);

        string auditMessage = "User dengan nama " + modelEmployee.EmployeeName + " mengunjungi Form Tambah Stok Penjualan.";
        await _audit.LogAsync(LogTypes.LogInfo, "Form Tambah Stok Penjualan", auditMessage, modelEmployee.EmployeeId, modelEmployee.EmployeeName);
    }

