@if (modelEmployee.EmployeeId == 5 || modelEmployee.EmployeeId == 6)
{
	<script type="text/javascript">
		$(document).ready(function () {
		

		@* window.setTimeout(function () {
			console.log("reload");
			window.location.reload();
		}, 60000); *@

		setInterval(time, 1000);
		});

		function time() {
			var d = new Date();
			var day = d.getDate();
			var month = d.toLocaleString('id-ID', { month: 'long' });;
			var year = d.getFullYear();
			var s = d.getSeconds();
			var m = d.getMinutes();
			var h = d.getHours();
			var span = document.getElementById('h5Tanggal');
			if(span) {
				span.textContent = day + " " + month + " " + year + " " +
					("0" + h).substr(-2) + ":" + ("0" + m).substr(-2) + ":" + ("0" + s).substr(-2);
			}
		}
	</script>
}

<script type="text/javascript">
	function downloadPdf(base64String, fileName) {
		const link = document.createElement('a');
		link.href = base64String;
		link.download = fileName;
		link.click();
	}
</script>

<script>
	window.downloadFileFromBase64 = (fileName, base64String) => {
		// Create a temporary hidden link
		const link = document.createElement('a');
		link.download = fileName;

		// Attach the base64 string as a PDF data URL
		link.href = 'data:application/pdf;base64,' + base64String;

		// Append to body, click it to trigger download, then remove it
		document.body.appendChild(link);
		link.click();
		document.body.removeChild(link);
	};
</script>
