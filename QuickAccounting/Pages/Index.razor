				ParamDataPdf.Add(LatestKontrakKerja.ContractDetails);
				ParamDataPdf.Add(LatestKontrakKerja.IsPermanent);
			}

			HtmlContentPdf = string.Format(@"<!DOCTYPE html>
								<html lang='en'>
								<head>
									<meta charset='UTF-8'>
									<meta name='viewport' content='width=device-width, initial-scale=1.0'>
									<title>Slip Gaji</title>
									<link rel='stylesheet' href='http://balungfarm.javahome.co.id/css/slipgaji.css' />
								</head>
								<body>
									<div class='payslip-container'>
										<!-- Payslip Header -->
										<div class='header'>
											<h1>Kontrak Kerja</h1>
											<p>PT Telur Intan Farm</p>
										</div>

										<!-- Employee Details -->
										<div class='details'>
											<table>
												<tr>
													<th>Nama Karyawan:</th>
													<td>{0}</td>
													<th>ID:</th>
													<td>{1}</td>
												</tr>
												<tr>
													<th>Jabatan:</th>
													<td colspan='3'>{2}</td>
												</tr>
												<tr>
													<th>Berlaku Mulai:</th>
													<td colspan='3'>{3}</td>
												</tr>
												<tr>
													<th>Sampai Dengan:</th>
													<td colspan='3'>{4}</td>
												</tr>
											</table>
										</div>

										<!-- Earnings Section -->
										<div class='earnings'>
											{5}
										</div>

										<!-- Payslip Footer -->
										<div class='footer'>
											<table style='width: 100%; border: 0px !important;'>
												<tr>
													<td style='width: 50%; border: 0px !important;' valign='top'>
														<br /><br />
														Karyawan<br />
														{0}

													</td>
													<td style='width: 50%; border: 0px !important;'>
														<br /><br />
														PT Telur Intan Farm <br />
														Manajemen HRD
														<br />
														<img src='http://balungfarm.javahome.co.id/img/ttd.png' style='width: 200px' />
													</td>
												</tr>		
											</table>										
										</div>
									</div>
								</body>
								</html>", ParamDataPdf.ToArray());

			var fileNamePdf = "kontrakkerja_" + modelEmployee.EmployeeName.Replace(" ", "_") + ".pdf";

			if (RuntimeInformation.OSDescription.Contains("Ubuntu"))
			{				
				//var pdfResult = await pdfService.GeneratePdf(HtmlContentPdf);

				// Initiate the download
				// Using Javascript to download PDF
				// var fileName = "slipgaji_" + namaKaryawan.Replace(" ", "_") + "_" + periode.Replace(" ", "_") + "_.pdf";
				//var base64 = Convert.ToBase64String(pdfResult);
				//var url = $"data:application/pdf;base64,{base64}";

				//await JSRuntime.InvokeVoidAsync("downloadPdf", url, fileNamePdf);
				string uniqueProfilePath = Path.Combine(Path.GetTempPath(), Guid.NewGuid().ToString());

				// 3. Launch the headless browser (NoSandbox is mandatory for Ubuntu)
				await using var browser = await Puppeteer.LaunchAsync(new LaunchOptions
				{
					Headless = true,
					UserDataDir = uniqueProfilePath,
					ExecutablePath = "/usr/bin/google-chrome-stable",
					Args = new[]
					{
						"--no-sandbox",
						"--disable-setuid-sandbox",
						"--disable-dev-shm-usage",
						"--disable-gpu"
					}
				});

				// 4. Create a new page and inject the HTML
				await using var page = await browser.NewPageAsync();
				await page.SetContentAsync(HtmlContentPdf);

				// 5. Generate and return the PDF file as a byte array
				byte[] pdfBytes = await page.PdfDataAsync(new PdfOptions
				{
					Format = PaperFormat.A4,
					PrintBackground = true,
					MarginOptions = new MarginOptions { Top = "10px", Bottom = "10px", Right = "40px" }
				});

				string base64Data = Convert.ToBase64String(pdfBytes);

				// 5. Call the JavaScript function to download the file
				await JSRuntime.InvokeVoidAsync("downloadFileFromBase64", fileNamePdf, base64Data);
			}
			else 
			{
				var pdfResult = await pdfService.GeneratePdf(HtmlContentPdf);

				// Initiate the download
				// Using Javascript to download PDF
				// var fileName = "slipgaji_" + namaKaryawan.Replace(" ", "_") + "_" + periode.Replace(" ", "_") + "_.pdf";
				var base64 = Convert.ToBase64String(pdfResult);
				var url = $"data:application/pdf;base64,{base64}";

				await JSRuntime.InvokeVoidAsync("downloadPdf", url, fileNamePdf);
			}


			Snackbar.Add("PDF berhasil diunduh!", Severity.Success);
		}
		catch (Exception ex)
		{
			Snackbar.Add($"Gagal mengunduh PDF: {ex.Message}", Severity.Error);
		}
	}

